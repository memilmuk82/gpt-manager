FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=sqlite:///instance/app.db
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Google Cloud Console OAuth Client settings.
# Local default: http://localhost:5000/auth/google/callback
# Production example: https://your-domain.example/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
ALLOWED_GOOGLE_DOMAIN=senedu.kr
# Comma-separated admin emails. Example: admin@senedu.kr,manager@senedu.kr
ADMIN_EMAILS=admin@senedu.kr

GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_INPUT_CHARS=3000
GEMINI_MAX_OUTPUT_TOKENS=1200
MAX_DAILY_AI_CALLS_PER_USER=50
