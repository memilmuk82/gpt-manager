# ==========================================================
# Git / VCS
# ==========================================================
.git
.gitignore

# ==========================================================
# Python
# ==========================================================
.venv
venv
env
__pycache__
*.py[cod]
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# ==========================================================
# Environment / Secrets
# 실제 .env는 이미지에 포함 금지
# docker-compose에서 env_file 또는 environment로 주입
# ==========================================================
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.crt
*.p12

firebase-adminsdk*.json
serviceAccount*.json
google-credentials*.json
gcp-*.json

# ==========================================================
# Flask local runtime
# ==========================================================
instance

# ==========================================================
# Local database / runtime data
# DB는 이미지가 아니라 volume/bind mount로 관리
# ==========================================================
data/*.db
data/*.sqlite
data/*.sqlite3
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db.sha256

# ==========================================================
# Node / Frontend
# node_modules는 이미지에 복사하지 않고 Dockerfile에서 설치
# ==========================================================
node_modules
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# 빌드 산출물이 Dockerfile에서 생성된다면 제외
# 이미 빌드된 static 파일을 복사하는 구조라면 dist/build 제외 여부 재검토
dist
build
.cache

# ==========================================================
# Test artifacts
# ==========================================================
test-results
playwright-report
coverage

# ==========================================================
# IDE / OS
# ==========================================================
.vscode
.idea
.DS_Store
Thumbs.db

# ==========================================================
# Backups / logs
# ==========================================================
backups
*.bak
*.backup
*.old
*.log

# ==========================================================
# Docs
# 기본적으로 docs는 이미지에서 제외한다.
# 단, 앱 런타임이 읽는 docs/legal/TERMS.md와 PRIVACY_POLICY.md는 아래 예외로 포함한다.
# ==========================================================
docs/
!docs/
!docs/legal/
docs/legal/*
!docs/legal/TERMS.md
!docs/legal/PRIVACY_POLICY.md
